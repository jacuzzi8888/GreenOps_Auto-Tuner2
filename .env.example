# ==========================================
# GreenOps Auto-Tuner Configuration
# ==========================================

# ------------------------------------------
# Server
# ------------------------------------------
PORT=3000

# ------------------------------------------
# GitLab Webhook & API
# ------------------------------------------
# Token expected in X-Gitlab-Token header for incoming webhooks
GITLAB_WEBHOOK_TOKEN=your_secure_webhook_secret

# Private token used to fetch MR file contents and post comments (requires 'api' scope)
GITLAB_API_TOKEN=glpat-your-gitlab-api-token

# ------------------------------------------
# Gemini AI
# ------------------------------------------
# Google AI Studio API key for Gemini 1.5 Pro
GEMINI_API_KEY=your_gemini_api_key

# ------------------------------------------
# Google Cloud Platform (GCP)
# ------------------------------------------
# API Key for accessing the Cloud Billing Catalog API
GCP_API_KEY=your_gcp_api_key

# ------------------------------------------
# Agent Apply Mode Configuration
# ------------------------------------------
# If 'true', agent will create commits with high-confidence proposals
APPLY_MODE=false

# Used to prevent loops if the agent commits changes back to the MR
AGENT_COMMIT_EMAIL=greenops-agent@example.com

# ------------------------------------------
# Audit Logging
# ------------------------------------------
# If 'true', analysis metadata will be written to JSON lines
ENABLE_AUDIT_LOG=true
AUDIT_LOG_PATH=/app/data/audit.log
